PORT=3001

# Primary AI provider (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Fallback AI provider (Groq) — used automatically when Gemini fails
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

AI_BATCH_SIZE=20
AI_MAX_CONCURRENCY=2
AI_MAX_RETRIES=3

# CORS — comma-separated list of allowed frontend origins.
# Use * to allow all (useful for Render free tier with Vercel preview URLs).
# Use https://*.vercel.app to allow all Vercel preview deploys.
# Example for production: https://groweasy.vercel.app,https://*.vercel.app
ALLOWED_ORIGINS=*
